# DirectLine secret from Copilot Studio "Configure web security" page
# https://learn.microsoft.com/en-us/microsoft-copilot-studio/configure-web-security
DIRECTLINE_SECRET=your_secret_here

# Optional: override base URL
DIRECTLINE_BASE_URL=https://directline.botframework.com/v3/directline

# Number of simultaneous virtual users during the real test phase
TARGET_CONCURRENCY=20

# Set to "true" to skip the warm-up phase and jump straight to the real test
SKIP_WARMUP=false

# Cooldown delay between warm-up and real test phases, in seconds (default: 120 = 2 minutes)
WARMUP_COOLDOWN_SECONDS=120

# Warm-up phase duration in seconds (default: 300 = 5 minutes)
WARMUP_DURATION_SECONDS=300

# Real test phase duration in seconds (default: 600 = 10 minutes)
TEST_DURATION_SECONDS=600

# Maximum requests per minute across all workers (global rate limit)
MAX_REQUESTS_PER_MINUTE=100

# Polling interval when waiting for bot response, in milliseconds
POLL_INTERVAL_MS=1000

# Maximum time to wait for a bot response before marking as timeout, in milliseconds
RESPONSE_TIMEOUT_MS=30000

# Output file path for results (will write both .json and .csv)
OUTPUT_FILE=./results/load-test

# SSO — enable to simulate authenticated users over the DirectLine channel
# Default grant type is auth_code (opens browser, supports MFA, works even if device code is blocked)
# Requires "Allow public client flows" enabled on the client SSO app registration in Azure Portal.
SSO_ENABLED=false
SSO_TENANT_ID=
SSO_CLIENT_ID=
SSO_SCOPE=
# SSO_CLIENT_SECRET=        # not needed for auth_code; required for client_credentials / password
# SSO_GRANT_TYPE=auth_code  # auth_code (default) | device_code | client_credentials | password
# SSO_REDIRECT_PORT=3000    # local callback port for auth_code flow
# SSO_TIMEOUT_MS=10000
# SSO_USERNAME=             # set together with SSO_PASSWORD to use password grant (ROPC)
# SSO_PASSWORD=
